-- RECOLOR

local function Recolor(bg, stroke, text)

    for _,v in pairs(Window.Root:GetDescendants()) do

        if v:IsA("Frame") then

            v.BackgroundColor3 = bg

        elseif v:IsA("TextLabel") or v:IsA("TextButton") then

            v.TextColor3 = text

        elseif v:IsA("UIStroke") then

            v.Color = stroke

        end

    end

end

Tabs.Main3:AddButton({

