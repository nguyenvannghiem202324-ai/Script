hàm cục bộ tpTo(obj)

   local char = player.Character

   if not char or not char:FindFirstChild("HumanoidRootPart") then return false end

   local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildWhichIsA("BasePart") or obj.PrimaryPart

   nếu là root thì

      char.HumanoidRootPart.CFrame = root.CFrame * CFrame.new(0,5,-5)

      trả về giá trị đúng

   kết thúc

   trả về false

