-- Brainrots Helpers (không thông báo spam)

hàm cục bộ getFolder(tp)

   local gf = workspace:FindFirstChild("GameFolder") or workspace

   local brNames = {"Brainrots", "BrainRots", "Brainrot", "BrainRotsFolder"}

   ngân hàng địa phương

   for _, n in brNames do br = gf:FindFirstChild(n) if br then break end end

   nếu không phải br thì trả về nil end

   local fNames = {}

   if tp == "Celestial" then fNames = {"Celestial", "Celestials", "Celestia"}

   elseif tp == "Secret" then fNames = {"Secret", "Secrets"}

   elseif tp == "God" then fNames = {"Godly", "God", "Divine", "Gods"}

   kết thúc

   for _, fn in fNames do local f = br:FindFirstChild(fn) if f then return f end end

   trả về nil

