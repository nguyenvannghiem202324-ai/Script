hàm cục bộ findRichest(folder)

   nếu không phải thư mục thì trả về nil.

   cục bộ giàu nhất, maxV, dự phòng = nil, -1, nil

   for _, obj in folder:GetChildren() do

      nếu obj:IsA("Model") hoặc obj:IsA("Folder") thì

         phương án dự phòng = phương án dự phòng hoặc obj

         local ls = obj:FindFirstChild("leaderstats") or obj:FindFirstChild("Leaderstats")

         nếu ls thì

            local v = ls:FindFirstChild("Farm") or ls:FindFirstChild("Cash") or ls:FindFirstChild("Money") or ls:FindFirstChild("Value") or ls:FindFirstChild("Brainrots")

            local val = v and v.Value or 0

            if val > maxV then maxV = val richest = obj end

         kết thúc

      kết thúc

   kết thúc

   trả về giá trị cao nhất hoặc giá trị dự phòng, maxV

